---
import HeaderLink from './HeaderLink.astro';
import { SITE_TITLE } from '../consts';
---

<header>
	<nav>
		<h2><a href="/">{SITE_TITLE}</a></h2>
		<div class="internal-links">
			<HeaderLink href="/">Home</HeaderLink>
			<HeaderLink href="/projects">Projects</HeaderLink>
			<HeaderLink href="/timeline">Timeline</HeaderLink>
			<a href="/Maxton_Herst_Resume.pdf" target="_blank" class="resume-button">Resume</a>
		</div>
	</nav>
</header>
<style>
	header {
		margin: 0;
		padding: 0 1em;
		background: #0b111a;
		box-shadow: 0 2px 8px rgba(0, 0, 0, 0.5);
	}
	h2 {
		margin: 0;
		font-size: 1.2em;
	}
	h2 a,
	h2 a.active {
		text-decoration: none;
		color: #ffffff; /* Ensures the title is white */
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		flex-wrap: wrap; /* This is the magic line that allows wrapping on mobile */
		padding: 1em 0;
	}
	.internal-links {
		display: flex;
		align-items: center;
		gap: 0.5em; /* Controls the spacing between the text links */
	}
	nav a {
		padding: 0.5em 0.8em;
		color: #e0e6ed;
		border-bottom: 4px solid transparent;
		text-decoration: none;
	}
	nav a.active {
		text-decoration: none;
		border-bottom-color: #FFCB05; /* Maize yellow active state */
	}
	.resume-button {
		margin-left: 0.5em;
		padding: 0.4em 1em;
		background-color: transparent;
		color: #e0e6ed;
		border: 1px solid #FFCB05;
		border-radius: 6px;
		text-decoration: none;
		font-weight: bold;
		transition: all 0.2s ease;
	}
	.resume-button:hover {
		background-color: #FFCB05;
		color: #0b111a;
	}

	/* Mobile Responsiveness */
	@media (max-width: 720px) {
		nav {
			justify-content: center; /* Centers title and links on mobile */
			gap: 1em; /* Adds space between the title row and link row */
		}
		.internal-links {
			justify-content: center;
			flex-wrap: wrap; /* Allows links to stack if screen is super narrow */
			gap: 0.2em;
		}
		nav a {
			font-size: 0.9em; /* Shrinks text slightly to fit better */
			padding: 0.5em 0.4em;
		}
	}
</style>