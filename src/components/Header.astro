---
import HeaderLink from './HeaderLink.astro';
import { SITE_TITLE } from '../consts';
---

<header>
	<nav>
		<h2><a href="/">{SITE_TITLE}</a></h2>
		<div class="internal-links">
			<HeaderLink href="/">Home</HeaderLink>
			<HeaderLink href="/projects">Projects</HeaderLink>
			<HeaderLink href="/timeline">Timeline</HeaderLink>
			<a href="/Herst_Maxton_Resume.pdf" target="_blank" class="resume-button">Resume</a>
		</div>
	</nav>
</header>
<style>
	header {
		margin: 0;
		/* Added more vertical padding to give space between the top/bottom edges */
		padding: 1.5em 2em; 
		background: #0b111a;
		box-shadow: 0 2px 8px rgba(0, 0, 0, 0.5);
	}
	h2 {
		margin: 0;
		font-size: 1.2em;
	}
	h2 a,
	h2 a.active {
		text-decoration: none;
		color: #ffffff;
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		flex-wrap: wrap;
		/* These two lines stop the links from flying to the far right on big monitors */
		max-width: 1000px; 
		margin: 0 auto; 
	}
	.internal-links {
		display: flex;
		align-items: center;
		/* Significantly increased the space between each link */
		gap: 2.5em; 
	}
	nav a {
		padding: 0.5em 0; 
		color: #e0e6ed;
		border-bottom: 4px solid transparent;
		text-decoration: none;
		font-weight: 500;
	}
	nav a.active {
		text-decoration: none;
		border-bottom-color: #FFCB05;
	}
	.resume-button {
		margin-left: 0.5em;
		padding: 0.5em 1.2em;
		background-color: transparent;
		color: #e0e6ed;
		border: 1px solid #FFCB05;
		border-radius: 6px;
		text-decoration: none;
		font-weight: bold;
		transition: all 0.2s ease;
	}
	.resume-button:hover {
		background-color: #FFCB05;
		color: #0b111a;
	}

	/* Mobile Responsiveness */
	@media (max-width: 720px) {
		header {
			padding: 1em; /* Tighter space for mobile */
		}
		nav {
			justify-content: center;
			gap: 1.5em; 
		}
		.internal-links {
			justify-content: center;
			flex-wrap: wrap;
			gap: 1em; /* Brings the links a bit closer together on small screens */
		}
		nav a {
			font-size: 0.9em;
		}
	}
</style>