---
import HeaderLink from './HeaderLink.astro';
import { SITE_TITLE } from '../consts';
---

<header>
	<nav>
		<div class="nav-left">
			<h2><a href="/">{SITE_TITLE}</a></h2>
		</div>

		<div class="internal-links">
			<HeaderLink href="/">Home</HeaderLink>
			<HeaderLink href="/projects">Projects</HeaderLink>
			<HeaderLink href="/timeline">Timeline</HeaderLink>
		</div>

		<div class="nav-right">
			<a href="/Herst_Maxton_Resume.pdf" target="_blank" class="resume-button">Resume</a>
		</div>
	</nav>
</header>

<style>
	header {
		margin: 0;
		/* Added more vertical padding to give plenty of space between the top/bottom edges */
		padding: 1.5em 2em; 
		background: #0b111a;
		box-shadow: 0 2px 8px rgba(0, 0, 0, 0.5);
	}

	/* The Grid Layout Engine */
	nav {
		display: grid;
		/* Creates 3 columns: equal left space, auto-sized middle, equal right space */
		grid-template-columns: 1fr auto 1fr; 
		align-items: center;
		max-width: 1000px; /* Constrains the width toward the middle of the page */
		margin: 0 auto; 
	}

	.nav-left {
		display: flex;
		justify-content: flex-start; /* Forces name to the far left */
	}

	h2 {
		margin: 0;
		font-size: 1.2em;
	}

	h2 a,
	h2 a.active {
		text-decoration: none;
		color: #ffffff;
	}

	.internal-links {
		display: flex;
		align-items: center;
		justify-content: center; 
		gap: 1.5em; 
	}

	.internal-links a {
		padding: 0.5em 0; 
		color: #e0e6ed;
		border-bottom: 4px solid transparent;
		text-decoration: none;
		font-weight: 500;
	}

	.internal-links a.active {
		text-decoration: none;
		border-bottom-color: #FFCB05;
	}

	.nav-right {
		display: flex;
		justify-content: flex-end;
		align-items: center;
	}

	.resume-button {
		display: block;
		box-sizing: border-box; 
		padding: 0.3em 0.8em;
		background-color: transparent;
		color: #e0e6ed;
		border: 1px solid #FFCB05;
		border-radius: 6px;
		text-decoration: none;
		font-weight: bold;
		transition: all 0.2s ease;
	}

	.resume-button:hover {
		background-color: #FFCB05;
		color: #0b111a;
	}

	/* Mobile Responsiveness */
	@media (max-width: 720px) {
		header {
			padding: 1em; 
		}
		
		nav {
			/* Switches back to Flexbox on small screens to easily stack items */
			display: flex;
			flex-direction: column; 
			gap: 1.5em; 
		}

		.nav-left, 
		.nav-right, 
		.internal-links {
			justify-content: center; /* Centers everything horizontally */
			width: 100%;
		}

		.internal-links {
			flex-wrap: wrap;
			gap: 1.5em; 
		}

		nav a {
			font-size: 0.9em;
		}
	}
</style>