---
import { getCollection } from 'astro:content';

// Fetch all projects and sort them by date (newest first)
const projects = await getCollection('projects');
projects.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<section class="timeline-section">
  <div class="timeline">
    
    {
      /* map() gives us the project AND its index (0, 1, 2...) */
      projects.map((project, index) => (
        /* If the index is even, put it on the left. If odd, put it on the right. */
        <div class={`timeline-item ${index % 2 === 0 ? 'left' : 'right'}`}>
          
          <a href={`/projects/${project.id}`} class="timeline-link">
            <div class="timeline-content">
              <h3>{project.data.title}</h3>
              
              <span class="date">
                {project.data.pubDate.toLocaleDateString('en-US', { month: 'short', year: 'numeric' })}
              </span>
              
              <div class="details">
                {/* Image appears here if it exists in frontmatter */}
                {project.data.heroImage && (
                  <img 
                    src={project.data.heroImage} 
                    alt={`Cover image for ${project.data.title}`} 
                    class="timeline-image"
                  />
                )}
                <p>{project.data.description}</p>
                {project.data.tags && (
                  <div class="tags">
                    {project.data.tags.map((tag) => (
                      <span class="tag">{tag}</span>
                    ))}
                  </div>
                )}
              </div>

            </div>
          </a>
        </div>
      ))
    }

  </div>
</section>

<style>
  .timeline-section {
    max-width: 800px;
    margin: 0 auto;
    padding: 40px 20px;
    font-family: sans-serif;
  }

  .timeline {
    position: relative;
    max-width: 1200px;
    margin: 0 auto;
  }

  /* The center vertical line */
  .timeline::after {
    content: '';
    position: absolute;
    width: 4px;
    background-color: #00274C; 
    top: 0;
    bottom: 0;
    left: 50%;
    margin-left: -2px;
  }

  .timeline-item {
    padding: 10px 40px;
    position: relative;
    width: 50%;
    box-sizing: border-box;
  }

  /* The dots on the timeline */
  .timeline-item::after {
    content: '';
    position: absolute;
    width: 20px;
    height: 20px;
    right: -10px;
    background-color: white;
    border: 4px solid #FFCB05; 
    top: 15px;
    border-radius: 50%;
    z-index: 1;
  }

  .left { left: 0; }
  .right { left: 50%; }

  .left::after { right: -14px; }
  .right::after { left: -14px; }

  /* Link Styling */
  .timeline-link {
    text-decoration: none;
    color: inherit;
    display: block;
  }

.timeline-content {
    padding: 20px;
    background-color: #151b26; /* Dark slate instead of #f4f4f4 */
    position: relative;
    border-radius: 8px;
    border: 1px solid #2a3441; /* Dark border instead of #e0e0e0 */
    transition: transform 0.3s ease, box-shadow 0.3s ease, background-color 0.3s ease;
    overflow: hidden;
  }

  .timeline-content:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 20px rgba(0,0,0,0.4);
    background-color: #1a2233; /* Slightly lighter slate on hover */
  }

.timeline-content h3 {
    margin: 0;
    color: #ffffff; /* Changed from #00274C to pure white */
    font-size: 1.25rem;
  }

.date {
    font-weight: bold;
    color: #a0aab5; /* Changed from #666 to a lighter gray */
    display: block;
    font-size: 0.9rem;
    margin-top: 5px;
  }

  /* === The Expanding Magic === */
  .details {
    max-height: 0;
    opacity: 0;
    /* Slowed down slightly (0.6s) so the image has time to reveal smoothly */
    transition: max-height 0.6s cubic-bezier(0, 1, 0, 1), opacity 0.4s ease-in-out, margin-top 0.4s ease-in-out;
  }

  /* When hovering over the content box, trigger the details to expand */
  .timeline-content:hover .details {
    /* Increased heavily to account for the image height + text */
    max-height: 1000px; 
    /* The cubic-bezier transition above makes this large number snap to the exact height needed */
    transition: max-height 0.6s ease-in-out, opacity 0.4s ease-in-out, margin-top 0.4s ease-in-out;
    opacity: 1;
    margin-top: 15px;
  }

  .timeline-image {
    width: 100%;
    max-width: 300px;
    border-radius: 8px;
    margin-bottom: 1em;
}

.details p {
    margin: 0 0 1rem 0;
    color: #e0e6ed; /* Changed from #555 to off-white */
    font-size: 0.95rem;
    line-height: 1.5;
  }

  .tags {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

.tag {
    background: #2a3441;
    color: #e0e6ed;
    padding: 0.2rem 0.6rem;
    border-radius: 4px;
    font-size: 0.8rem;
    font-weight: bold;
  }
</style>