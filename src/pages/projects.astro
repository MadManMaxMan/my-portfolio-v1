---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';

// 1. Import the getCollection function
import { getCollection } from 'astro:content';

// 2. Fetch all projects and sort them by date (newest first)
const projects = await getCollection('projects');
projects.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={`Projects | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
    <style>
      .projects-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
        gap: 2rem;
        list-style: none;
        padding: 0;
        margin-top: 2rem;
      }
      
      .project-card {
        border: 1px solid #e0e0e0;
        border-radius: 8px;
        overflow: hidden;
        transition: transform 0.2s ease, box-shadow 0.2s ease;
        background: #ffffff;
        height: 100%;
        display: flex;
        flex-direction: column;
      }
      
      .project-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 20px rgba(0,0,0,0.1);
      }
      
      .project-card img {
        width: 100%;
        height: 200px;
        object-fit: cover;
      }
      
      .project-content {
        padding: 1.5rem;
        flex-grow: 1;
        display: flex;
        flex-direction: column;
      }
      
      .project-content h3 {
        margin: 0 0 0.5rem 0;
        color: #00274C;
        font-size: 1.25rem;
      }
      
      .project-content p {
        margin: 0 0 1rem 0;
        color: #555;
        font-size: 0.95rem;
        line-height: 1.5;
      }
      
      .tags {
        display: flex;
        gap: 0.5rem;
        flex-wrap: wrap;
        margin-top: auto; /* Pushes tags to the bottom of the card */
      }
      
      .tag {
        background: #f4f4f4;
        color: #333;
        padding: 0.2rem 0.6rem;
        border-radius: 4px;
        font-size: 0.8rem;
        font-weight: bold;
      }
      
      a {
        text-decoration: none;
        color: inherit;
      }
    </style>
  </head>
  <body>
    <Header />
    <main>
      <h1>Primary Projects</h1>
      <p>A selection of my engineering work, ranging from aerospace research to custom marine fabrication.</p>
      
      <ul class="projects-grid">
        {
          /* 3. Loop through the projects array and generate HTML for each one */
          projects.map((project) => (
            <li>
              <a href={`/projects/${project.id}`}>
                <div class="project-card">
                  <img 
                    src={project.data.heroImage || "https://via.placeholder.com/600x400?text=Project+Image"} 
                    alt={project.data.title} 
                  />
                  <div class="project-content">
                    <h3>{project.data.title}</h3>
                    <p>{project.data.description}</p>
                    
                    {/* Check if tags exist, then map through them */}
                    {project.data.tags && (
                      <div class="tags">
                        {project.data.tags.map((tag) => (
                          <span class="tag">{tag}</span>
                        ))}
                      </div>
                    )}
                  </div>
                </div>
              </a>
            </li>
          ))
        }
      </ul>
    </main>
    <Footer />
  </body>
</html>