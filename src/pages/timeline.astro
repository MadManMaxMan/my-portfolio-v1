---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Timeline from '../components/Timeline.astro'; // Importing your building block!
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={`Timeline | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Header />
    <main>
      <h1>Project Timeline</h1>
      <p>My projects chronologized, showing my track record of dreaming and achieving.</p>
      
      <Timeline /> 
      
    </main>
    <Footer />
  </body>
</html>